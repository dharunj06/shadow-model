# Application
APP_NAME=ShadowML
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/shadowml
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/shadowml

# Model Services
MODEL_V1_URL=http://localhost:8001
MODEL_V2_URL=http://localhost:8002

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Prometheus
PROMETHEUS_PORT=8000

# Shadow evaluation
PROMOTION_THRESHOLD=100
PROMOTION_ACCURACY_DELTA=0.02

# JWT Auth
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
